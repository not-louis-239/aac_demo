{
    "$schema": "./nodes.schema.json",
    "_comment": [
        "The UNIVERSAL node describes nodes to include on every screen.",
        "Negative integers for a destination are relative indicators as to how many history steps to go back.",
        "Negative coordinates describe a number of cells from the last row or column.",
        "The `.` directory refers to the `assets/images` directory relative to the project root.",
        "Row -1 (bottom row) is reserved for UNIVERSAL nodes.",
        "Grid is 6x6 for standard usability. Hence grid coordinate indices are in [-6..-1] U [0..5]"
    ],
    "nodes": {
        "UNIVERSAL": {
            "buttons": [
                { "label": "Home", "dest": "HOME", "coords": [0, -1], "type": "system" },
                { "label": "Back", "dest": -1, "coords": [1, -1], "type": "system" }
            ]
        },
        "HOME": {
            "buttons": [
                { "label": "I", "word": "I", "img": "./core/i.png", "coords": [0, 0], "type": "pronoun" },
                { "label": "Want", "word": "want", "img": "./core/want.png", "coords": [1, 0], "type": "verb" },
                { "label": "More", "word": "more", "img": "./core/more.png", "coords": [2, 0], "type": "descriptor" },
                { "label": "Stop", "word": "stop", "img": "./core/stop.png", "coords": [3, 0], "type": "verb" },

                { "label": "Go", "word": "go", "img": "./core/go.png", "coords": [0, 1], "type": "verb" },
